   RowBox[{
    RowBox[{
     RowBox[{"ConditionalSimulation", "[", 
      RowBox[{"uncondField_", ",", "measurementFile_"}], "]"}], ":=", 
     RowBox[{"Module", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
        "dataMeasurements", ",", "xLoc", ",", "yLoc", ",", "measurementLoc", 
