   "\[IndentingNewLine]", "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"GenerateRandomField", "[", "]"}], ":=", 
     RowBox[{"Module", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
        "fourierCoeffs", ",", "scalingFactor", ",", "fieldRealization", ",", 
         "finalField"}], "}"}], ",", 
       RowBox[{
        RowBox[{"fourierCoeffs", "=", 
         RowBox[{"ConstantArray", "[", 
          RowBox[{"0", ",", 
           RowBox[{"{", 
            RowBox[{"nx", ",", "ny"}], "}"}]}], "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"scalingFactor", "=", 
         RowBox[{"(", 
          RowBox[{"nx", "*", "ny", "*", 
           RowBox[{"Sqrt", "[", "4", "]"}]}], ")"}]}], ";", " ", 
        RowBox[{"(*", 
         RowBox[{
          RowBox[{"Sqrt", "[", "number", "]"}], " ", "adjustment", " ", 
          "depedning", " ", "on", " ", "the", " ", "grid", " ", "size"}], 
         "*)"}], "\[IndentingNewLine]", 
        RowBox[{"(*", 
         RowBox[{"Generate", " ", "random", " ", "coefficients"}], "*)"}], 
        RowBox[{"Do", "[", 
         RowBox[{
          RowBox[{"Module", "[", 
           RowBox[{
            RowBox[{"{", 
             RowBox[{
             "kx", ",", "ky", ",", "Sval", ",", "amp", ",", "coeff", ",", 
