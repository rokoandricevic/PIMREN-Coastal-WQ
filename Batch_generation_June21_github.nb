                 "\[IndentingNewLine]", 
                RowBox[{
                 RowBox[{"fourierCoeffs", "[", 
                  RowBox[{"[", 
                   RowBox[{"i", ",", "j"}], "]"}], "]"}], "=", "coeff"}], ";",
                 "\[IndentingNewLine]", 
                RowBox[{"(*", 
                 RowBox[{"Set", " ", "symmetric", " ", "coefficients"}], 
                 "*)"}], 
                RowBox[{"iSym", "=", 
                 RowBox[{"First", "@", 
                  RowBox[{"First", "@", 
                   RowBox[{"Position", "[", 
                    RowBox[{"kxList", ",", 
                    RowBox[{"-", "kx"}]}], "]"}]}]}]}], ";", 
                "\[IndentingNewLine]", 
                RowBox[{"jSym", "=", 
                 RowBox[{"First", "@", 
                  RowBox[{"First", "@", 
                   RowBox[{"Position", "[", 
                    RowBox[{"kyList", ",", 
                    RowBox[{"-", "ky"}]}], "]"}]}]}]}], ";", 
                "\[IndentingNewLine]", 
                RowBox[{
                 RowBox[{"fourierCoeffs", "[", 
                  RowBox[{"[", 
                   RowBox[{"iSym", ",", "jSym"}], "]"}], "]"}], "=", 
                 RowBox[{"Conjugate", "[", "coeff", "]"}]}], ";"}]}], 
              "]"}]}]}], "]"}], ",", 
          RowBox[{"{", 
           RowBox[{"i", ",", "1", ",", "nx"}], "}"}], ",", 
          RowBox[{"{", 
