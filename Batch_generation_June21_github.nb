            RowBox[{
             RowBox[{"kx", "=", 
              RowBox[{"kxList", "[", 
               RowBox[{"[", "i", "]"}], "]"}]}], ";", 
             RowBox[{"ky", "=", 
              RowBox[{"kyList", "[", 
               RowBox[{"[", "j", "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
             RowBox[{"Sval", "=", 
              RowBox[{"spectrumFunction", "[", 
               RowBox[{"kx", ",", "ky"}], "]"}]}], ";", "\[IndentingNewLine]", 
             RowBox[{"amp", "=", 
              RowBox[{"Sqrt", "[", "Sval", "]"}]}], ";", 
             "\[IndentingNewLine]", 
             RowBox[{"If", "[", 
              RowBox[{
               RowBox[{
                RowBox[{"(", 
                 RowBox[{"kx", ">", "0"}], ")"}], "||", 
