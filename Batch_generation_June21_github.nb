             RowBox[{"{", 
              RowBox[{"j", ",", "0", ",", 
               RowBox[{"ny", "-", "1"}]}], "}"}]}], "]"}], ",", "1"}], 
          "]"}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"predictedValues", "=", 
         RowBox[{"spf", "/@", "gridPoints"}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"predictedMatrix", "=", 
         RowBox[{
          RowBox[{"Partition", "[", 
           RowBox[{"predictedValues", ",", "ny"}], "]"}], "+", 
