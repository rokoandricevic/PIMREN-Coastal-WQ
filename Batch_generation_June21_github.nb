        "\[IndentingNewLine]", "\[IndentingNewLine]", 
        RowBox[{"(*", 
         RowBox[{"Create", " ", "conditional", " ", "field"}], "*)"}], 
        "\[IndentingNewLine]", 
        RowBox[{"conditionalField", "=", 
         RowBox[{"uncondField", "+", "predictedMatrix"}]}], ";", 
        "\[IndentingNewLine]", "\[IndentingNewLine]", 
        RowBox[{"(*", 
         RowBox[{"Handle", " ", "negatives"}], "*)"}], "\[IndentingNewLine]", 
        
        RowBox[{"negativeMassCon", "=", 
         RowBox[{"Total", "[", 
          RowBox[{"Select", "[", 
           RowBox[{
            RowBox[{"Flatten", "[", "conditionalField", "]"}], ",", 
