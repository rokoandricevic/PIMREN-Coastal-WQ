             RowBox[{"#", "<", "0"}], "&"}]}], "]"}], "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"If", "[", 
         RowBox[{
          RowBox[{"negativeMassCon", "<", "0"}], ",", 
          RowBox[{
           RowBox[{"weightsCon", "=", 
            RowBox[{"Clip", "[", 
             RowBox[{"conditionalField", ",", 
              RowBox[{"{", 
               RowBox[{"0", ",", "Infinity"}], "}"}]}], "]"}]}], ";", 
           "\[IndentingNewLine]", 
           RowBox[{"normalizedWeightsCon", "=", 
            RowBox[{"weightsCon", "/", 
             RowBox[{"Total", "[", 
              RowBox[{"weightsCon", ",", "Infinity"}], "]"}]}]}], ";", 
           "\[IndentingNewLine]", 
           RowBox[{"redistAmountsCon", "=", 
            RowBox[{"normalizedWeightsCon", "*", 
             RowBox[{"(", 
              RowBox[{"-", "negativeMassCon"}], ")"}]}]}], ";", 
           "\[IndentingNewLine]", 
           RowBox[{"conditionalField", "=", 
            RowBox[{
             RowBox[{"Clip", "[", 
              RowBox[{"conditionalField", ",", 
               RowBox[{"{", 
                RowBox[{"0", ",", "Infinity"}], "}"}]}], "]"}], "+", 
             "redistAmountsCon"}]}], ";"}]}], "]"}], ";", 
        "\[IndentingNewLine]", "\[IndentingNewLine]", 
        RowBox[{"(*", 
         RowBox[{"Create", " ", "data", " ", "triples"}], "*)"}], 
        RowBox[{"dataCond", "=", 
         RowBox[{"Flatten", "[", 
          RowBox[{
           RowBox[{"Table", "[", 
            RowBox[{
             RowBox[{"{", 
              RowBox[{
               RowBox[{"xCoords", "[", 
                RowBox[{"[", 
                 RowBox[{"i", "+", "1"}], "]"}], "]"}], ",", 
               RowBox[{"yCoords", "[", 
                RowBox[{"[", 
                 RowBox[{"j", "+", "1"}], "]"}], "]"}], ",", 
               RowBox[{"conditionalField", "[", 
                RowBox[{"[", 
                 RowBox[{
                  RowBox[{"i", "+", "1"}], ",", 
                  RowBox[{"j", "+", "1"}]}], "]"}], "]"}]}], "}"}], ",", 
             RowBox[{"{", 
              RowBox[{"i", ",", "0", ",", 
               RowBox[{"nx", "-", "1"}]}], "}"}], ",", 
             RowBox[{"{", 
              RowBox[{"j", ",", "0", ",", 
               RowBox[{"ny", "-", "1"}]}], "}"}]}], "]"}], ",", "1"}], 
          "]"}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"{", 
         RowBox[{"conditionalField", ",", "dataCond"}], "}"}]}]}], "]"}]}], 
    ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{"Coordinate", " ", "conversion", " ", "function"}], "*)"}], "\n", 
   
   RowBox[{
    RowBox[{
     RowBox[{"cartesianToGeo", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"x_", ",", "y_"}], "}"}], ",", "originLat_", ",", 
       "originLon_"}], "]"}], ":=", 
     RowBox[{"Module", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{"originGeo", "=", 
          RowBox[{"GeoPosition", "[", 
           RowBox[{"{", 
            RowBox[{"originLat", ",", "originLon"}], "}"}], "]"}]}], ",", 
         "distance", ",", "bearingDeg"}], "}"}], ",", 
       RowBox[{
        RowBox[{"distance", "=", 
         RowBox[{"Sqrt", "[", 
          RowBox[{
           RowBox[{"x", "^", "2"}], "+", 
           RowBox[{"y", "^", "2"}]}], "]"}]}], ";", 
        RowBox[{"(*", 
         RowBox[{"Distance", " ", "in", " ", "meters"}], "*)"}], 
        RowBox[{"bearingDeg", "=", 
         RowBox[{"Mod", "[", 
          RowBox[{
           RowBox[{"90", "-", 
            RowBox[{"(", 
             RowBox[{
              RowBox[{"ArcTan", "[", 
               RowBox[{"x", ",", "y"}], "]"}], "*", 
              RowBox[{"180", "/", "Pi"}]}], ")"}]}], ",", "360"}], "]"}]}], 
        ";", "\[IndentingNewLine]", 
        RowBox[{"GeoDestination", "[", 
         RowBox[{"originGeo", ",", 
          RowBox[{"{", 
           RowBox[{"distance", ",", "bearingDeg"}], "}"}]}], "]"}]}]}], 
      "]"}]}], ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{"===", 
     RowBox[{"==", 
      RowBox[{"BATCH", " ", "PROCESSING"}]}], "===", "=="}], "*)"}], 
   RowBox[{"(*", "Parameters", "*)"}], "\n", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"numRealizations", "=", "100"}], ";"}], " ", 
   RowBox[{"(*", 
    RowBox[{
    "Number", " ", "of", " ", "random", " ", "fields", " ", "to", " ", 
     "generate"}], "*)"}], "\n", 
   RowBox[{
    RowBox[{"originLat", "=", "43.5"}], ";"}], "    ", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{"Origin", " ", "Geo"}], "-", 
     RowBox[{"Reference", " ", "latitude"}]}], "*)"}], "\n", 
   RowBox[{
    RowBox[{"originLon", "=", "16.4"}], ";"}], "    ", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{"Origin", " ", "Geo"}], "-", 
     RowBox[{"Reference", " ", "longitude"}]}], "*)"}], "\[IndentingNewLine]",
    "\n", 
   RowBox[{"(*", " ", 
    RowBox[{"===", 
     RowBox[{"==", " ", 
      RowBox[{
      "Change", " ", "the", " ", "directory", " ", "name", " ", "with", " ", 
       "in", " ", "situ", " ", "Chl", " ", "samples", " ", "and", " ", 
       "Output", " ", "directory", " ", "for", " ", "generated", " ", 
       "realizations"}]}], "===", "=="}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
    "measurementFile", "=", 
     "\"\</SetDirectory[NotebookDirectory[]]/In_situ samples/CHL/JuneCart.csv\
\>\""}], ";"}], "\n", 
   RowBox[{
    RowBox[{
    "outputDir", "=", 
     "\"\</SetDirectory[NotebookDirectory[]]/Realizations_1000June\>\""}], 
    ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{"Initialize", " ", "model"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"InitializeParameters", "[", "]"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"DefineSpectrumFunctions", "[", "]"}], ";"}], "\n", 
   "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{"Store", " ", "all", " ", "statistics"}], "*)"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"allStats", "=", 
     RowBox[{"{", 
      RowBox[{"{", 
       RowBox[{
       "\"\<Realization\>\"", ",", "\"\<Mean\>\"", ",", "\"\<Variance\>\"", 
        ",", "\"\<Min\>\"", ",", "\"\<Max\>\"", ",", "\"\<NegativeMass\>\""}],
        "}"}], "}"}]}], ";"}], "\n", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{"Generate", " ", "and", " ", "export", " ", "realizations"}], 
    "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Do", "[", 
     RowBox[{"(*", 
      RowBox[{"Generate", " ", "fields"}], "*)"}], 
     RowBox[{
      RowBox[{
       RowBox[{"uncondField", "=", 
        RowBox[{"GenerateRandomField", "[", "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"conditionalField", ",", "dataCond"}], "}"}], "=", 
        RowBox[{"ConditionalSimulation", "[", 
         RowBox[{"uncondField", ",", "measurementFile"}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"(*", 
        RowBox[{"Compute", " ", "statistics"}], "*)"}], 
       RowBox[{"meanChl", "=", 
        RowBox[{"Mean", "[", 
         RowBox[{"dataCond", "[", 
          RowBox[{"[", 
           RowBox[{"All", ",", "3"}], "]"}], "]"}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"varChl", "=", 
        RowBox[{"Variance", "[", 
         RowBox[{"dataCond", "[", 
          RowBox[{"[", 
           RowBox[{"All", ",", "3"}], "]"}], "]"}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"minChl", "=", 
        RowBox[{"Min", "[", 
         RowBox[{"dataCond", "[", 
          RowBox[{"[", 
           RowBox[{"All", ",", "3"}], "]"}], "]"}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"maxChl", "=", 
        RowBox[{"Max", "[", 
         RowBox[{"dataCond", "[", 
          RowBox[{"[", 
           RowBox[{"All", ",", "3"}], "]"}], "]"}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"negativeMassCon", "=", 
        RowBox[{"Total", "[", 
         RowBox[{"Select", "[", 
          RowBox[{
           RowBox[{"Flatten", "[", "conditionalField", "]"}], ",", 
           RowBox[{
            RowBox[{"#", "<", "0"}], "&"}]}], "]"}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"(*", 
        RowBox[{"Convert", " ", "to", " ", "geographic", " ", "coordinates"}],
         "*)"}], "\[IndentingNewLine]", 
       RowBox[{"geoData", "=", 
        RowBox[{"Table", "[", 
         RowBox[{
          RowBox[{
           RowBox[{
            RowBox[{"{", 
             RowBox[{"x", ",", "y", ",", "chl"}], "}"}], "=", 
            RowBox[{"dataCond", "[", 
             RowBox[{"[", "i", "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
           RowBox[{
            RowBox[{"{", 
             RowBox[{"lat", ",", "lon"}], "}"}], "=", 
            RowBox[{"First", "[", 
             RowBox[{"cartesianToGeo", "[", 
              RowBox[{
               RowBox[{"{", 
                RowBox[{
                 RowBox[{"x", "*", "1000"}], ",", 
                 RowBox[{"y", "*", "1000"}]}], "}"}], ",", "originLat", ",", 
               "originLon"}], "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
           RowBox[{"{", 
            RowBox[{"lat", ",", "lon", ",", "chl"}], "}"}]}], ",", 
          RowBox[{"{", 
           RowBox[{"i", ",", "1", ",", 
            RowBox[{"Length", "[", "dataCond", "]"}]}], "}"}]}], "]"}]}], ";",
        "\[IndentingNewLine]", 
       RowBox[{"(*", 
        RowBox[{"Export", " ", "realization", " ", "to", " ", "CSV"}], "*)"}], 
       RowBox[{"exportPath", "=", 
        RowBox[{"FileNameJoin", "[", 
         RowBox[{"{", 
          RowBox[{"outputDir", ",", 
           RowBox[{"\"\<Realization_\>\"", "<>", 
            RowBox[{"ToString", "[", "n", "]"}], "<>", "\"\<.csv\>\""}]}], 
          "}"}], "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"Export", "[", 
        RowBox[{"exportPath", ",", 
         RowBox[{"Prepend", "[", 
          RowBox[{"geoData", ",", 
           RowBox[{"{", 
            RowBox[{
            "\"\<Latitude\>\"", ",", "\"\<Longitude\>\"", ",", 
             "\"\<Chl\>\""}], "}"}]}], "]"}], ",", "\"\<CSV\>\""}], "]"}], 
       ";", "\[IndentingNewLine]", "\[IndentingNewLine]", 
       RowBox[{"(*", 
        RowBox[{"Export", " ", "field", " ", "array"}], "*)"}], 
       RowBox[{"fieldPath", "=", 
        RowBox[{"FileNameJoin", "[", 
         RowBox[{"{", 
          RowBox[{"outputDir", ",", 
           RowBox[{"\"\<Field_\>\"", "<>", 
            RowBox[{"ToString", "[", "n", "]"}], "<>", "\"\<.wdx\>\""}]}], 
          "}"}], "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"Export", "[", 
        RowBox[{"fieldPath", ",", "conditionalField"}], "]"}], ";", 
       "\[IndentingNewLine]", "\[IndentingNewLine]", 
       RowBox[{"(*", 
        RowBox[{
        "Append", " ", "statistics", " ", "for", " ", "this", " ", 
         "realization"}], "*)"}], 
       RowBox[{"AppendTo", "[", 
        RowBox[{"allStats", ",", 
         RowBox[{"{", 
          RowBox[{
          "n", ",", "meanChl", ",", "varChl", ",", "minChl", ",", "maxChl", 
           ",", "negativeMass"}], "}"}]}], "]"}], ";"}], 
      "\[IndentingNewLine]", 
      RowBox[{"(*", 
       RowBox[{
        RowBox[{"Print", "[", 
         RowBox[{"\"\<Completed realization \>\"", ",", "n"}], "]"}], ";"}], 
       "*)"}], ",", 
      RowBox[{"{", 
       RowBox[{"n", ",", "1", ",", "numRealizations"}], "}"}]}], "]"}], ";"}],
    "\[IndentingNewLine]", "\n", 
   RowBox[{"(*", 
    RowBox[{"Export", " ", "comprehensive", " ", "statistics", " ", "file"}], 
    "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"statsPath", "=", 
     RowBox[{"FileNameJoin", "[", 
      RowBox[{"{", 
       RowBox[{"outputDir", ",", "\"\<FieldStatistics.csv\>\""}], "}"}], 
      "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"Export", "[", 
     RowBox[{"statsPath", ",", "allStats", ",", "\"\<CSV\>\""}], "]"}], ";"}],
    "\n", 
   RowBox[{
    RowBox[{"Print", "[", "\"\<Batch processing complete!\>\"", "]"}], 
    ";"}]}]}]], "Input",
