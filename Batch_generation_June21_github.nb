             RowBox[{"#", "<", "0"}], "&"}]}], "]"}], "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"If", "[", 
         RowBox[{
          RowBox[{"negativeMass", "<", "0"}], ",", 
          RowBox[{
           RowBox[{"weights", "=", 
            RowBox[{"Clip", "[", 
