       RowBox[{
        RowBox[{"dataMeasurements", "=", 
         RowBox[{"Import", "[", "measurementFile", "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"xLoc", "=", 
         RowBox[{"dataMeasurements", "[", 
          RowBox[{"[", 
           RowBox[{"All", ",", "1"}], "]"}], "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"yLoc", "=", 
         RowBox[{"dataMeasurements", "[", 
          RowBox[{"[", 
           RowBox[{"All", ",", "2"}], "]"}], "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"measurementLoc", "=", 
         RowBox[{"Transpose", "[", 
          RowBox[{"{", 
           RowBox[{"xLoc", ",", "yLoc"}], "}"}], "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"samples", "=", 
         RowBox[{"dataMeasurements", "[", 
          RowBox[{"[", 
           RowBox[{"All", ",", "3"}], "]"}], "]"}]}], ";", 
        "\[IndentingNewLine]", "\[IndentingNewLine]", 
        RowBox[{"(*", 
         RowBox[{"Create", " ", "interpolation"}], "*)"}], 
        RowBox[{"interpUncond", "=", 
         RowBox[{"ListInterpolation", "[", 
          RowBox[{"uncondField", ",", 
           RowBox[{"{", 
            RowBox[{
             RowBox[{"{", 
              RowBox[{
               RowBox[{"Min", "[", "xCoords", "]"}], ",", 
