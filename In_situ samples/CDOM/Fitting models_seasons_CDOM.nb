Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"randomDataNov", "=", 
   RowBox[{
   "Import", "[", 
    "\"\</Users/rokoandricevic/Dropbox/Python_scripts/CNN/Multi_CDOM/\
Realizations_Nov_CDOM_ave/Averaged_Realization.csv\>\"", "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"randomDataNov", "=", 
    RowBox[{"Rest", "[", "randomDataNov", "]"}]}], ";"}], "\n", 
  RowBox[{"(*", " ", 
   RowBox[{"Random", " ", "Data", " ", "Extraction"}], 
   "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"longCoordsNov", "=", 
   RowBox[{"randomDataNov", "[", 
    RowBox[{"[", 
     RowBox[{"All", ",", "2"}], "]"}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"latCoordsNov", "=", 
   RowBox[{"randomDataNov", "[", 
    RowBox[{"[", 
     RowBox[{"All", ",", "1"}], "]"}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"randomChlNov", "=", 
    RowBox[{"randomDataNov", "[", 
     RowBox[{"[", 
      RowBox[{"All", ",", "3"}], "]"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{
   "list", " ", "of", " ", "points", " ", "where", " ", "you", " ", "want", 
    " ", "the", " ", "interpolation"}], "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"pointsNov", "=", 
    RowBox[{"Transpose", "[", 
     RowBox[{"{", 
      RowBox[{"longCoordsNov", ",", "latCoordsNov"}], "}"}], "]"}]}], ";"}], 
  "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{"Import", " ", "Chl", " ", "samples"}], 
   "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"ChlDataNov", "=", 
   RowBox[{
   "Import", "[", 
    "\"\</Users/rokoandricevic/Dropbox/Python_scripts/CNN/Multi_CDOM/Data_\
CDOM/Nov22DataCDOM.csv\>\"", "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"ChlDataNov", "=", 
    RowBox[{"Rest", "[", "ChlDataNov", "]"}]}], ";"}], "\[IndentingNewLine]", 
  
  RowBox[{"(*", " ", 
   RowBox[{"In", "-", 
    RowBox[{"situ", " ", "Data", " ", "Extraction"}]}], 
   "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"longLocNov", "=", 
   RowBox[{"ChlDataNov", "[", 
    RowBox[{"[", 
     RowBox[{"All", ",", "2"}], "]"}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"latLocNov", "=", 
   RowBox[{"ChlDataNov", "[", 
    RowBox[{"[", 
     RowBox[{"All", ",", "1"}], "]"}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"ChlsamplesNov", "=", 
   RowBox[{"ChlDataNov", "[", 
    RowBox[{"[", 
     RowBox[{"All", ",", "3"}], "]"}], "]"}]}], ";"}], "\[IndentingNewLine]", 

 RowBox[{
  RowBox[{
   RowBox[{"measurementLocNov", "=", 
    RowBox[{"Transpose", "[", 
     RowBox[{"{", 
      RowBox[{"longLocNov", ",", "latLocNov"}], "}"}], "]"}]}], ";"}], 
  "\[IndentingNewLine]", "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{
    RowBox[{
    "Evaluate", " ", "interpolation", " ", "function", " ", "at", " ", 
     "random", " ", "data", " ", "points"}], ")"}], "*)"}]}], "\n", 
 RowBox[{
  RowBox[{"interpValuesNov", "=", 
   RowBox[{"interpFuncNov", "/@", "pointsNov"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"interpValuesChlNov", "=", 
   RowBox[{"interpFuncNov", "/@", "measurementLocNov"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"(*", 
   RowBox[{"Make", " ", "a", " ", "paired", " ", "dataset", "  ", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"sample", "\[NonBreakingSpace]", "Chl"}], ",", 
      RowBox[{"interpolated", " ", "reflectance"}]}], "}"}]}], "*)"}], 
  RowBox[{
   RowBox[{"pairedDataNov", "=", 
    RowBox[{"Transpose", "[", 
     RowBox[{"{", 
      RowBox[{"interpValuesNov", ",", "randomChlNov"}], "}"}], "]"}]}], 
   ";"}]}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"pairedDataChlNov", "=", 
    RowBox[{"Transpose", "[", 
