      RowBox[{"All", ",", "3"}], "]"}], "]"}]}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"bandsComboB4B5", "=", 
   RowBox[{
    RowBox[{"satDataB4", "[", 
     RowBox[{"[", 
      RowBox[{"All", ",", "3"}], "]"}], "]"}], "/", 
    RowBox[{"satDataB5", "[", 
     RowBox[{"[", 
      RowBox[{"All", ",", "3"}], "]"}], "]"}]}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"NDCI", "=", 
   RowBox[{
    RowBox[{"(", 
     RowBox[{
      RowBox[{"satDataB5", "[", 
       RowBox[{"[", 
        RowBox[{"All", ",", "3"}], "]"}], "]"}], "-", 
      RowBox[{"satDataB4", "[", 
       RowBox[{"[", 
        RowBox[{"All", ",", "3"}], "]"}], "]"}]}], ")"}], "/", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"satDataB5", "[", 
       RowBox[{"[", 
        RowBox[{"All", ",", "3"}], "]"}], "]"}], "+", 
      RowBox[{"satDataB4", "[", 
       RowBox[{"[", 
        RowBox[{"All", ",", "3"}], "]"}], "]"}]}], ")"}]}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"bandsComboB3B4d", "=", 
   RowBox[{
    RowBox[{"satDataB3", "[", 
     RowBox[{"[", 
      RowBox[{"All", ",", "3"}], "]"}], "]"}], "-", 
    RowBox[{"satDataB4", "[", 
     RowBox[{"[", 
      RowBox[{"All", ",", "3"}], "]"}], "]"}]}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"hybridB2B3B4", "=", 
    RowBox[{
     RowBox[{"satDataB3", "[", 
      RowBox[{"[", 
       RowBox[{"All", ",", "3"}], "]"}], "]"}], "/", 
     RowBox[{"(", 
      RowBox[{
       RowBox[{"satDataB2", "[", 
        RowBox[{"[", 
         RowBox[{"All", ",", "3"}], "]"}], "]"}], "+", 
       RowBox[{"satDataB4", "[", 
        RowBox[{"[", 
         RowBox[{"All", ",", "3"}], "]"}], "]"}]}], ")"}]}]}], ";"}], 
  "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{"Models", " ", "selction"}], "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"ChlmodelPow", "=", 
    RowBox[{
     RowBox[{"a", "*", 
      SuperscriptBox["x", "b"]}], "+", "c"}]}], ";"}], " ", 
  RowBox[{"(*", "Power", "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"ChlmodelPoly", "=", 
    RowBox[{"a", "+", 
     RowBox[{"b", "*", "x"}], "+", 
     RowBox[{"c", "*", 
      SuperscriptBox["x", "2"]}]}]}], ";"}], " ", 
  RowBox[{"(*", 
   RowBox[{"Ploynomial", ")"}], "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"ChlmodelLin", "=", 
    RowBox[{
     RowBox[{"a", "*", "x"}], "+", "b"}]}], ";"}], "  ", 
  RowBox[{"(*", "Linear", "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"ChlmodelExp", "=", 
    RowBox[{"a", "*", 
     RowBox[{"Exp", "[", 
      RowBox[{"b", "*", "x"}], "]"}]}]}], ";"}], "  ", 
  RowBox[{"(*", "Exponential", "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"ChlmodelLog", "=", 
    RowBox[{"a", "+", 
     RowBox[{"b", "*", 
      RowBox[{"Log", "[", "x", "]"}]}]}]}], ";"}], "  ", 
  RowBox[{"(*", "Logarithmic", "*)"}], "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{"Select", " ", "bands", " ", "combination"}], "*)"}]}], "\n", 
 RowBox[{
  RowBox[{"ratioSelect", "=", "bandsComboB2B3"}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{"MinMax", "[", "ratioSelect", "]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"coords", "=", 
    RowBox[{"satDataB2", "[", 
     RowBox[{"[", 
      RowBox[{"All", ",", 
       RowBox[{"{", 
        RowBox[{"1", ",", "2"}], "}"}]}], "]"}], "]"}]}], ";"}], " ", 
  RowBox[{"(*", 
   RowBox[{"{", 
    RowBox[{"lon", ",", " ", "lat"}], "}"}], "*)"}], "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{"Build", " ", "Nearest", " ", "function"}], 
   "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"nearestFuncJune", "=", 
   RowBox[{"Nearest", "[", 
    RowBox[{"coords", "->", "ratioSelect"}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"interpFuncJune", "[", "pt_", "]"}], ":=", 
  RowBox[{"First", "@", 
   RowBox[{"nearestFuncJune", "[", "pt", "]"}]}]}]}], "Input",
