Cell["\<\
Import average random Chlorophyll fields and Chl data from the sampling \
sessions\
\>", "Text",
 CellFrame->{{0, 0}, {0, 0}},
 CellChangeTimes->{{3.954425698948065*^9, 3.954425767778221*^9}, {
   3.954425808097955*^9, 3.954425828368135*^9}, {3.954426720372388*^9, 
   3.954426721218395*^9}, {3.954846723115859*^9, 3.954846723847034*^9}, {
   3.956918012386504*^9, 3.9569180174573097`*^9}, 3.956928931556665*^9},
 Background->RGBColor[
  0.87, 0.94, 1],ExpressionUUID->"82e13a20-7bd0-4066-9429-1f3d55c165c4"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"randomDataMarch", "=", 
   RowBox[{
   "Import", "[", 
    "\"\</Users/rokoandricevic/Dropbox/Python_scripts/CNN/Multi_CDOM/\
Realizations_March_CDOM_ave/Averaged_Realization.csv\>\"", "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"randomDataMarch", "=", 
    RowBox[{"Rest", "[", "randomDataMarch", "]"}]}], ";"}], "\n", 
  RowBox[{"(*", " ", 
   RowBox[{"Random", " ", "Data", " ", "Extraction"}], 
   "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"longCoordsMarch", "=", 
   RowBox[{"randomDataMarch", "[", 
    RowBox[{"[", 
     RowBox[{"All", ",", "2"}], "]"}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"latCoordsMarch", "=", 
   RowBox[{"randomDataMarch", "[", 
    RowBox[{"[", 
     RowBox[{"All", ",", "1"}], "]"}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"randomChlMarch", "=", 
    RowBox[{"randomDataMarch", "[", 
     RowBox[{"[", 
      RowBox[{"All", ",", "3"}], "]"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{
   "list", " ", "of", " ", "points", " ", "where", " ", "you", " ", "want", 
    " ", "the", " ", "interpolation"}], "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"pointsMarch", "=", 
    RowBox[{"Transpose", "[", 
     RowBox[{"{", 
      RowBox[{"longCoordsMarch", ",", "latCoordsMarch"}], "}"}], "]"}]}], 
   ";"}], "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{"Import", " ", "Chl", " ", "samples"}], 
   "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"ChlDataMarch", "=", 
   RowBox[{
   "Import", "[", 
    "\"\</Users/rokoandricevic/Dropbox/Python_scripts/CNN/Multi_CDOM/Data_\
CDOM/March22DataCDOM.csv\>\"", "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"ChlDataMarch", "=", 
    RowBox[{"Rest", "[", "ChlDataMarch", "]"}]}], ";"}], 
  "\[IndentingNewLine]", 
  RowBox[{"(*", " ", 
   RowBox[{"In", "-", 
    RowBox[{"situ", " ", "Data", " ", "Extraction"}]}], 
   "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"longLocMarch", "=", 
   RowBox[{"ChlDataMarch", "[", 
    RowBox[{"[", 
     RowBox[{"All", ",", "2"}], "]"}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"latLocMarch", "=", 
   RowBox[{"ChlDataMarch", "[", 
    RowBox[{"[", 
     RowBox[{"All", ",", "1"}], "]"}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"ChlsamplesMarch", "=", 
   RowBox[{"ChlDataMarch", "[", 
    RowBox[{"[", 
     RowBox[{"All", ",", "3"}], "]"}], "]"}]}], ";"}], "\[IndentingNewLine]", 

 RowBox[{
  RowBox[{
   RowBox[{"measurementLocMarch", "=", 
    RowBox[{"Transpose", "[", 
     RowBox[{"{", 
      RowBox[{"longLocMarch", ",", "latLocMarch"}], "}"}], "]"}]}], ";"}], 
  "\n", 
  RowBox[{"(*", 
   RowBox[{
    RowBox[{
    "Evaluate", " ", "interpolation", " ", "function", " ", "at", " ", 
     "random", " ", "data", " ", "points"}], ")"}], "*)"}]}], "\n", 
 RowBox[{
  RowBox[{"interpValuesMarch", "=", 
   RowBox[{"interpFuncMarch", "/@", "pointsMarch"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"interpValuesChlMarch", "=", 
   RowBox[{"interpFuncMarch", "/@", "measurementLocMarch"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"(*", 
   RowBox[{"Make", " ", "a", " ", "paired", " ", "dataset", "  ", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"sample", "\[NonBreakingSpace]", "Chl"}], ",", 
      RowBox[{"interpolated", " ", "reflectance"}]}], "}"}]}], "*)"}], 
  RowBox[{
   RowBox[{"pairedDataMarch", "=", 
    RowBox[{"Transpose", "[", 
     RowBox[{"{", 
      RowBox[{"interpValuesMarch", ",", "randomChlMarch"}], "}"}], "]"}]}], 
   ";"}]}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"pairedDataChlMarch", "=", 
    RowBox[{"Transpose", "[", 
     RowBox[{"{", 
      RowBox[{"interpValuesChlMarch", ",", "ChlsamplesMarch"}], "}"}], 
     "]"}]}], ";"}], "\n", "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{"Fitting", " ", "random", " ", "Chl", " ", "data"}], 
   "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"nlmMarch", "=", 
   RowBox[{"NonlinearModelFit", "[", 
    RowBox[{"pairedDataMarch", ",", "ChlmodelExp", ",", 
     RowBox[{"{", 
      RowBox[{"a", ",", "b"}], "}"}], ",", "x"}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"Print", "[", 
   RowBox[{"\"\<Chl model =\>\"", ",", 
    RowBox[{"Normal", "[", "nlmMarch", "]"}], ",", "\"\<   RMSE =\>\"", ",", 
    RowBox[{"Sqrt", "[", 
     RowBox[{"Mean", "[", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{"nlmMarch", "[", "\"\<FitResiduals\>\"", "]"}], ")"}], "^", 
       "2"}], "]"}], "]"}]}], "]"}], 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"plotFitMarch", ":=", 
