Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"randomDataJune", "=", 
   RowBox[{
   "Import", "[", 
    "\"\</Users/rokoandricevic/Dropbox/Python_scripts/CNN/Multi_CDOM/\
Realizations_June_CDOM_ave/Averaged_Realization.csv\>\"", "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"randomDataJune", "=", 
    RowBox[{"Rest", "[", "randomDataJune", "]"}]}], ";"}], "\n", 
  RowBox[{"(*", " ", 
   RowBox[{"Random", " ", "Data", " ", "Extraction"}], 
   "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"longCoordsJune", "=", 
   RowBox[{"randomDataJune", "[", 
    RowBox[{"[", 
     RowBox[{"All", ",", "2"}], "]"}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"latCoordsJune", "=", 
   RowBox[{"randomDataJune", "[", 
    RowBox[{"[", 
     RowBox[{"All", ",", "1"}], "]"}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"randomChlJune", "=", 
    RowBox[{"randomDataJune", "[", 
     RowBox[{"[", 
      RowBox[{"All", ",", "3"}], "]"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{
   "list", " ", "of", " ", "points", " ", "where", " ", "you", " ", "want", 
    " ", "the", " ", "interpolation"}], "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"pointsJune", "=", 
    RowBox[{"Transpose", "[", 
     RowBox[{"{", 
      RowBox[{"longCoordsJune", ",", "latCoordsJune"}], "}"}], "]"}]}], ";"}],
   "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{"Import", " ", "Chl", " ", "samples"}], 
   "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"ChlDataJune", "=", 
   RowBox[{
   "Import", "[", 
    "\"\</Users/rokoandricevic/Dropbox/Python_scripts/CNN/Multi_CDOM/Data_\
CDOM/June21DataCDOM.csv\>\"", "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"ChlDataJune", "=", 
    RowBox[{"Rest", "[", "ChlDataJune", "]"}]}], ";"}], "\[IndentingNewLine]", 
  RowBox[{"(*", " ", 
   RowBox[{"In", "-", 
    RowBox[{"situ", " ", "Data", " ", "Extraction"}]}], 
   "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"longLocJune", "=", 
   RowBox[{"ChlDataJune", "[", 
    RowBox[{"[", 
     RowBox[{"All", ",", "2"}], "]"}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"latLocJune", "=", 
   RowBox[{"ChlDataJune", "[", 
    RowBox[{"[", 
     RowBox[{"All", ",", "1"}], "]"}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"ChlsamplesJune", "=", 
   RowBox[{"ChlDataJune", "[", 
    RowBox[{"[", 
     RowBox[{"All", ",", "3"}], "]"}], "]"}]}], ";"}], "\[IndentingNewLine]", 

 RowBox[{
  RowBox[{
   RowBox[{"measurementLocJune", "=", 
    RowBox[{"Transpose", "[", 
     RowBox[{"{", 
      RowBox[{"longLocJune", ",", "latLocJune"}], "}"}], "]"}]}], ";"}], 
  "\[IndentingNewLine]", "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{
    RowBox[{
    "Evaluate", " ", "interpolation", " ", "function", " ", "at", " ", 
     "random", " ", "data", " ", "points"}], ")"}], "*)"}]}], "\n", 
 RowBox[{
  RowBox[{"interpValuesJune", "=", 
   RowBox[{"interpFuncJune", "/@", "pointsJune"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"interpValuesChlJune", "=", 
   RowBox[{"interpFuncJune", "/@", "measurementLocJune"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"(*", 
   RowBox[{"Make", " ", "a", " ", "paired", " ", "dataset", "  ", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"sample", "\[NonBreakingSpace]", "Chl"}], ",", 
      RowBox[{"interpolated", " ", "reflectance"}]}], "}"}]}], "*)"}], 
  RowBox[{
   RowBox[{"pairedDataJune", "=", 
    RowBox[{"Transpose", "[", 
     RowBox[{"{", 
      RowBox[{"interpValuesJune", ",", "randomChlJune"}], "}"}], "]"}]}], 
   ";"}]}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"pairedDataChlJune", "=", 
    RowBox[{"Transpose", "[", 
     RowBox[{"{", 
      RowBox[{"interpValuesChlJune", ",", "ChlsamplesJune"}], "}"}], "]"}]}], 
   ";"}], "\n", "\n", 
  RowBox[{"(*", 
   RowBox[{"Fitting", " ", "random", " ", "Chl", " ", "data"}], 
   "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"nlmJune", "=", 
   RowBox[{"NonlinearModelFit", "[", 
    RowBox[{"pairedDataJune", ",", "ChlmodelExp", ",", 
     RowBox[{"{", 
      RowBox[{"a", ",", "b"}], "}"}], ",", "x"}], "]"}]}], ";"}], "\n", 
 RowBox[{"Print", "[", 
  RowBox[{"\"\<Chl model =\>\"", ",", 
   RowBox[{"Normal", "[", "nlmJune", "]"}], ",", "\"\<   RMSE =\>\"", ",", 
   RowBox[{"Sqrt", "[", 
    RowBox[{"Mean", "[", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{"nlmJune", "[", "\"\<FitResiduals\>\"", "]"}], ")"}], "^", 
      "2"}], "]"}], "]"}]}], "]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"plotFitJune", ":=", 
    RowBox[{"Plot", "[", 
     RowBox[{
      RowBox[{"nlmJune", "[", "x", "]"}], ",", 
      RowBox[{"{", 
       RowBox[{"x", ",", 
        RowBox[{"Min", "[", "ratioSelect", "]"}], ",", 
        RowBox[{"Max", "[", "ratioSelect", "]"}]}], "}"}], ",", 
      RowBox[{"PlotStyle", "->", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"Thickness", "[", "0.007", "]"}], ",", "Black"}], "}"}]}], 
      ",", 
      RowBox[{"PlotLegends", "->", 
       RowBox[{"Placed", "[", 
        RowBox[{
         RowBox[{"LineLegend", "[", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{"Directive", "[", 
             RowBox[{"Black", ",", 
              RowBox[{"AbsoluteThickness", "[", "3.5", "]"}]}], "]"}], "}"}], 
           ",", 
           RowBox[{"{", "\"\<Fitted model upscaled\>\"", "}"}], ",", 
           RowBox[{"LabelStyle", "->", 
            RowBox[{"Directive", "[", 
             RowBox[{"16", ",", 
              RowBox[{"FontFamily", "->", "\"\<Calibri\>\""}]}], "]"}]}]}], 
          "]"}], ",", 
         RowBox[{"{", 
          RowBox[{"0.8", ",", "0.15"}], "}"}]}], "]"}]}]}], "]"}]}], ";"}], 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{"nlmJune", "[", 
  RowBox[{"{", 
   RowBox[{"\"\<RSquared\>\"", ",", "\"\<ParameterTable\>\""}], "}"}], 
  "]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Grid", "[", 
   RowBox[{
    RowBox[{"Transpose", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"{", 
        RowBox[{"#", ",", 
         RowBox[{"nlmJune", "[", "#", "]"}]}], "}"}], "&"}], "[", 
      RowBox[{"{", 
       RowBox[{
       "\"\<AdjustedRSquared\>\"", ",", "\"\<AIC\>\"", ",", "\"\<BIC\>\"", 
        ",", "\"\<RSquared\>\""}], "}"}], "]"}], "]"}], ",", 
    RowBox[{"Alignment", "\[Rule]", "Left"}]}], "]"}], "\[IndentingNewLine]", 
  "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{"Fitting", " ", "directly", " ", "Chl", " ", "data"}], 
   "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"nlmChlJune", "=", 
   RowBox[{"NonlinearModelFit", "[", 
    RowBox[{"pairedDataChlJune", ",", "ChlmodelExp", ",", 
     RowBox[{"{", 
      RowBox[{"a", ",", "b"}], "}"}], ",", "x"}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"plotFitChlJune", ":=", 
    RowBox[{"Plot", "[", 
     RowBox[{
      RowBox[{"nlmChlJune", "[", "x", "]"}], ",", 
      RowBox[{"{", 
       RowBox[{"x", ",", 
        RowBox[{"Min", "[", "interpValuesChlJune", "]"}], ",", 
        RowBox[{"Max", "[", "interpValuesChlJune", "]"}]}], "}"}], ",", 
      RowBox[{"PlotStyle", "->", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"Thickness", "[", "0.01", "]"}], ",", "Blue", ",", 
         "Dashed"}], "}"}]}], ",", 
      RowBox[{"PlotLegends", "->", 
       RowBox[{"Placed", "[", 
        RowBox[{
         RowBox[{"LineLegend", "[", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{"Directive", "[", 
             RowBox[{
              RowBox[{"{", 
               RowBox[{"Blue", ",", "Dashed"}], "}"}], ",", 
              RowBox[{"AbsoluteThickness", "[", "3.5", "]"}]}], "]"}], "}"}], 
           ",", 
