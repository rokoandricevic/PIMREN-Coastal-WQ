      RowBox[{"All", ",", "3"}], "]"}], "]"}]}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"bandsComboB3B4", "=", 
   RowBox[{
    RowBox[{"satDataB3", "[", 
     RowBox[{"[", 
      RowBox[{"All", ",", "3"}], "]"}], "]"}], "/", 
    RowBox[{"satDataB4", "[", 
