      SuperscriptBox["x", "2"]}]}]}], ";"}], " ", 
  RowBox[{"(*", 
   RowBox[{"Ploynomial", ")"}], "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"ChlmodelLin", "=", 
