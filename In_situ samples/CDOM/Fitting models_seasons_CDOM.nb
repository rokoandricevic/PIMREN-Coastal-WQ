 RowBox[{
  RowBox[{"satDataB5", "=", 
   RowBox[{
   "Import", "[", 
    "\"\</Users/rokoandricevic/Dropbox/Matematica files/Satellite \
data/20210626/Filtered_SAT_polygons/filtered_B05_20m.csv\>\"", "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"satDataB5", "=", 
