 RowBox[{
  RowBox[{
   RowBox[{"ChlmodelPow", "=", 
    RowBox[{
     RowBox[{"a", "*", 
      SuperscriptBox["x", "b"]}], "+", "c"}]}], ";"}], " ", 
  RowBox[{"(*", "Power", "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
