  "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{"Band", " ", "combination", " ", "models"}], " ", "*)"}]}], "\n", 
 RowBox[{
  RowBox[{"bandsComboB2B3", "=", 
   RowBox[{
    RowBox[{"satDataB2", "[", 
     RowBox[{"[", 
      RowBox[{"All", ",", "3"}], "]"}], "]"}], "/", 
