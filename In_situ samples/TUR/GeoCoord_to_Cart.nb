Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{"Define", " ", "the", " ", "origin", " ", "coordinates"}], "*)"}], 
  "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"originLat", "=", "43.5"}], ";"}], " ", 
   RowBox[{"(*", 
    RowBox[{"Example", " ", "origin", " ", "latitude"}], "*)"}], "\n", 
   RowBox[{
    RowBox[{"originLon", "=", "16.4"}], ";"}], "\n", 
   RowBox[{"(*", 
    RowBox[{"Function", " ", "to", " ", "convert", " ", 
     RowBox[{"lat", "/", "lon"}], " ", "to", " ", "Cartesian", " ", 
     "coordinates"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"cartesianCoordinates", "[", 
     RowBox[{"lat_", ",", "lon_"}], "]"}], ":=", 
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
        RowBox[{"originGeo", "=", 
         RowBox[{"GeoPosition", "[", 
          RowBox[{"{", 
           RowBox[{"originLat", ",", "originLon"}], "}"}], "]"}]}], ",", 
        RowBox[{"pointGeo", "=", 
         RowBox[{"GeoPosition", "[", 
          RowBox[{"{", 
           RowBox[{"lat", ",", "lon"}], "}"}], "]"}]}], ",", "distance"}], 
       "}"}], ",", 
      RowBox[{
       RowBox[{"distance", "=", 
        RowBox[{"GeoDistance", "[", 
         RowBox[{"originGeo", ",", "pointGeo"}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"{", 
        RowBox[{"(*", 
         RowBox[{
         "Assuming", " ", "North", " ", "is", " ", "positive", " ", "Y", " ", 
          "and", " ", "East", " ", "is", " ", "positive", " ", "X"}], "*)"}], 
        
        RowBox[{
         RowBox[{"distance", "*", 
          RowBox[{"Sin", "[", 
           RowBox[{"GeoDirection", "[", 
            RowBox[{"originGeo", ",", "pointGeo"}], "]"}], "]"}]}], ",", 
         RowBox[{"distance", "*", 
          RowBox[{"Cos", "[", 
           RowBox[{"GeoDirection", "[", 
            RowBox[{"originGeo", ",", "pointGeo"}], "]"}], "]"}]}]}], 
        "}"}]}]}], "]"}]}], "\n", 
   RowBox[{"(*", 
    RowBox[{"Convert", " ", "coordinates"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"cartesianCoords", "=", 
     RowBox[{"Table", "[", 
      RowBox[{
       RowBox[{"cartesianCoordinates", "[", 
        RowBox[{
         RowBox[{"latitudes", "[", 
          RowBox[{"[", "i", "]"}], "]"}], ",", 
         RowBox[{"longitudes", "[", 
          RowBox[{"[", "i", "]"}], "]"}]}], "]"}], ",", 
       RowBox[{"{", 
        RowBox[{"i", ",", "1", ",", 
         RowBox[{"Length", "[", "latitudes", "]"}]}], "}"}]}], "]"}]}], ";"}],
    "\n", 
   RowBox[{"(*", 
    RowBox[{"Create", " ", "a", " ", "list", " ", "of", " ", 
     RowBox[{"{", 
      RowBox[{"x", ",", "y", ",", "attribute"}], "}"}], " ", "tuples"}], 
    "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"dataWithCartesian", "=", 
     RowBox[{"Transpose", "[", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"cartesianCoords", "[", 
         RowBox[{"[", 
          RowBox[{"All", ",", "1"}], "]"}], "]"}], ",", 
        RowBox[{"cartesianCoords", "[", 
         RowBox[{"[", 
          RowBox[{"All", ",", "2"}], "]"}], "]"}], ",", "attributes"}], "}"}],
       "]"}]}], ";"}], "\n", 
   RowBox[{"(*", 
    RowBox[{"Print", " ", "the", " ", "results"}], "*)"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
    "Print", "[", "\"\<Cartesian Coordinates and Attributes:\>\"", "]"}], 
    ";"}], "\n", "\"\<Cartesian Coordinates and Attributes:\>\"", "\n", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"TableForm", "[", 
      RowBox[{"dataWithCartesian", ",", 
       RowBox[{"TableHeadings", "->", 
        RowBox[{"{", 
         RowBox[{"{", 
          RowBox[{"\"\<X\>\"", ",", "\"\<Y\>\"", ",", "\"\<Attribute\>\""}], 
          "}"}], "}"}]}]}], "]"}], "]"}], ";"}]}]}]], "Input",
